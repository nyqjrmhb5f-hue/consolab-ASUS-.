{
  "name": "consolelab-authority",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "build": "rm -rf dist && mkdir -p dist/src && cp -R src/. dist/src/",
    "smoke": "node scripts/smoke.mjs",
    "test": "node --test src/services/__tests__/*.test.js src/routes/__tests__/*.test.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0"
  }
}
